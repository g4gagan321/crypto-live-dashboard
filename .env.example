# ==============================================================
# Crypto Live Dashboard — Environment Variables
# Copy this file to .env.local for local development, or configure
# the same keys in your Vercel project settings for production.
# ALL keys are optional — the dashboard degrades gracefully to free,
# no-key endpoints (CoinGecko public API, alternative.me, CryptoCompare
# public news feed) when a key is not supplied.
# ==============================================================

# --- AngelOne SmartAPI (live Nifty 50 / Bank Nifty / India VIX) ---
# Free with a personal AngelOne trading + demat account. Create an app at
# https://smartapi.angelone.in to get ANGELONE_API_KEY. ANGELONE_CLIENT_CODE
# and ANGELONE_PASSWORD are your normal login ID and password/MPIN.
# ANGELONE_TOTP_SECRET is the base32 secret shown when you enable "TOTP"
# under Profile > Settings in the AngelOne app (same secret you'd scan into
# Google Authenticator) — NOT a 6-digit code, the underlying secret string.
# If any of these four are missing, Nifty 50 / Bank Nifty fall back to a
# delayed Yahoo Finance feed and India VIX shows "unavailable".
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# --- CoinGecko ---
# Free tier works without a key (rate-limited ~10-30 req/min).
# Get a Demo/Pro key at https://www.coingecko.com/en/api/pricing for higher limits.
COINGECKO_API_KEY=

# --- CryptoCompare (news + market data fallback) ---
# Free key: https://min-api.cryptocompare.com/
CRYPTOCOMPARE_API_KEY=

# --- Whale Alert (whale-alert.io) ---
# Paid API required for real on-chain whale transaction data.
# Without a key, the dashboard shows a clearly labeled simulated feed
# so the on-screen layout is never empty during a live broadcast.
WHALE_ALERT_API_KEY=

# --- NewsAPI.org (optional secondary headline source) ---
NEWSAPI_KEY=

# --- OpenWeather (weather widget) ---
# Free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Mumbai,IN

# --- General ---
# Base refresh interval overrides (ms). Optional — defaults live in
# config/dashboard.config.json and can be edited there instead.
NEXT_PUBLIC_REFRESH_CRYPTO_MS=
NEXT_PUBLIC_REFRESH_NEWS_MS=
